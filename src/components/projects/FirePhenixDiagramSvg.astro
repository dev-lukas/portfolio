---
interface Props {
  large?: boolean;
}

const { large = false } = Astro.props;

const nodes = [
  { id: 'repo', kicker: 'Source', label: 'GitHub Repos', detail: ['Backend', 'frontend'], x: 58, y: 74, w: 148, h: 88, tone: 'green' },
  { id: 'ci', kicker: 'CI/CD', label: 'GitHub Actions', detail: ['Build + test', 'deploy'], x: 282, y: 74, w: 160, h: 88, tone: 'green' },
  { id: 'runner', kicker: 'Runner', label: 'HomeServer Runner', detail: ['Self-hosted', 'deploy target'], x: 526, y: 68, w: 178, h: 100, tone: 'green' },
  { id: 'compose', kicker: 'Runtime', label: 'Docker Compose', detail: ['Health checks', 'restart order'], x: 384, y: 218, w: 172, h: 88, tone: 'green' },

  { id: 'nginx', kicker: 'Edge', label: 'Nginx', detail: ['TLS', 'static SPA'], x: 60, y: 334, w: 132, h: 88, tone: 'blue' },
  { id: 'home', kicker: 'UI', label: 'Vue Homepage', detail: ['Stats + rankings', 'profiles'], x: 250, y: 330, w: 160, h: 88, tone: 'blue' },
  { id: 'api', kicker: 'API', label: 'Flask Gateway', detail: ['Auth + rate limits', 'JSON API'], x: 492, y: 320, w: 184, h: 98, tone: 'blue' },
  { id: 'valkey', kicker: 'Cache + bus', label: 'Valkey', detail: ['Pub/Sub + cache', 'rate limits'], x: 754, y: 270, w: 142, h: 88, tone: 'fire' },
  { id: 'mariadb', kicker: 'State', label: 'MariaDB', detail: ['Users + sessions', 'activity data'], x: 754, y: 406, w: 142, h: 88, tone: 'fire' },

  { id: 'discord', kicker: 'Bot', label: 'Discord Bot', detail: ['Commands + AI chat'], x: 128, y: 532, w: 158, h: 76, tone: 'purple' },
  { id: 'teamspeak', kicker: 'Bot', label: 'TeamSpeak Bot', detail: ['Voice tracking'], x: 388, y: 532, w: 158, h: 76, tone: 'purple' },
  { id: 'external', kicker: 'Platforms', label: 'Steam / Discord / TS3', detail: ['Identity + events'], x: 648, y: 532, w: 196, h: 76, tone: 'purple' },
];

const edges = [
  { d: 'M206 118 C238 118 250 118 282 118', tone: 'green', delay: '0s' },
  { d: 'M442 118 C474 118 494 118 526 118', tone: 'green', delay: '-1.4s' },
  { d: 'M614 168 C604 194 580 222 556 250', tone: 'green', delay: '-2.5s' },
  { d: 'M384 252 C290 260 218 296 172 334', tone: 'green', delay: '-2s' },
  { d: 'M430 306 C406 318 390 324 370 330', tone: 'green', delay: '-2.7s' },
  { d: 'M556 254 C612 258 708 262 754 286', tone: 'green', delay: '-3.2s' },
  { d: 'M556 282 C624 336 698 392 754 440', tone: 'green', delay: '-0.6s' },
  { d: 'M506 306 C504 312 502 316 500 320', tone: 'green', delay: '-1.6s' },
  { d: 'M448 306 C382 412 282 462 218 532', tone: 'green', delay: '-1.1s' },
  { d: 'M488 306 C472 390 468 454 468 532', tone: 'green', delay: '-2.3s' },
  { d: 'M192 374 C212 374 228 374 250 374', tone: 'blue', delay: '-3.6s' },
  { d: 'M192 398 C312 426 422 402 492 366', tone: 'blue', delay: '-0.4s' },
  { d: 'M410 370 C444 370 460 370 492 370', tone: 'blue', delay: '-1.9s' },
  { d: 'M410 394 C444 420 460 420 492 398', tone: 'blue', delay: '-3.1s' },
  { d: 'M676 352 C706 326 726 312 754 306', tone: 'blue', delay: '-0.8s' },
  { d: 'M676 384 C710 416 728 438 754 450', tone: 'blue', delay: '-2.8s' },
  { d: 'M286 570 C350 546 432 484 524 418', tone: 'purple', delay: '-1.2s' },
  { d: 'M546 570 C562 510 578 452 594 418', tone: 'purple', delay: '-2.2s' },
  { d: 'M648 570 C610 518 620 462 654 418', tone: 'purple', delay: '-3.8s' },
];

const toneClass = {
  fire: 'tone-fire',
  blue: 'tone-blue',
  green: 'tone-green',
  purple: 'tone-purple',
};

const toneColors = {
  fire: '#E85D2C',
  blue: '#4A8FE7',
  green: '#4CAF50',
  purple: '#8B7CFF',
};

const markerId = (tone: keyof typeof toneColors) => `fp-arrow-${tone}${large ? '-large' : ''}`;
---

<svg
  class:list={['firephenix-architecture-svg', { 'is-large': large }]}
  viewBox="0 0 940 650"
  role="img"
  aria-labelledby={large ? 'fp-architecture-title-large fp-architecture-desc-large' : 'fp-architecture-title fp-architecture-desc'}
>
  <title id={large ? 'fp-architecture-title-large' : 'fp-architecture-title'}>FirePhenix deployment and runtime workflow</title>
  <desc id={large ? 'fp-architecture-desc-large' : 'fp-architecture-desc'}>
    Diagram showing GitHub Actions deploying to a home server runner, Docker Compose running Nginx, the Vue homepage, Flask API, Valkey, MariaDB, Discord bot and TeamSpeak bot integrations.
  </desc>

  <defs>
    <filter id={large ? 'fp-glow-large' : 'fp-glow'} x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="4" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <linearGradient id={large ? 'fp-panel-large' : 'fp-panel'} x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" stop-color="#1A1A26" stop-opacity="0.92" />
      <stop offset="100%" stop-color="#0A0A0F" stop-opacity="0.96" />
    </linearGradient>
    <radialGradient id={large ? 'fp-core-large' : 'fp-core'} cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#E85D2C" stop-opacity="0.22" />
      <stop offset="70%" stop-color="#E85D2C" stop-opacity="0.04" />
      <stop offset="100%" stop-color="#E85D2C" stop-opacity="0" />
    </radialGradient>
    {Object.entries(toneColors).map(([tone, color]) => (
      <marker id={markerId(tone as keyof typeof toneColors)} viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill={color} fill-opacity="0.82" />
      </marker>
    ))}
  </defs>

  <rect class="diagram-bg" x="0" y="0" width="940" height="650" rx="20" />
  <path class="diagram-grid" d="M0 190H940M0 510H940M224 190V650M704 190V650" />
  <rect class="scope-shell delivery-shell" x="30" y="42" width="704" height="146" rx="18" />
  <rect class="scope-shell runtime-shell" x="30" y="204" width="880" height="418" rx="18" />
  <ellipse class="core-glow" cx="588" cy="374" rx="230" ry="180" fill={`url(#${large ? 'fp-core-large' : 'fp-core'})`} />

  <g class="lane-labels">
    <text x="52" y="64">delivery pipeline</text>
    <text x="52" y="228">runtime stack</text>
    <text x="52" y="514">event workers</text>
  </g>

  <g class="edges">
    {edges.map((edge) => (
      <path class:list={['architecture-link', toneClass[edge.tone]]} d={edge.d} marker-end={`url(#${markerId(edge.tone as keyof typeof toneColors)})`} style={`--delay:${edge.delay}`} />
    ))}
  </g>

  <g class="nodes">
    {nodes.map((node) => (
      <g class:list={['architecture-node', toneClass[node.tone]]} transform={`translate(${node.x} ${node.y})`}>
        <rect class="node-shell" width={node.w} height={node.h} rx="10" />
        <rect class="node-accent" width="3" height={node.h - 20} x="12" y="10" rx="1.5" />
        <text class="node-kicker" x="26" y="25">{node.kicker}</text>
        <text class="node-label" x="26" y="47">{node.label}</text>
        <text class="node-detail" x="26" y={node.detail.length > 1 ? 64 : node.h - 16}>
          {node.detail.map((line, index) => (
            <tspan x="26" dy={index === 0 ? 0 : 13}>{line}</tspan>
          ))}
        </text>
      </g>
    ))}
  </g>
</svg>

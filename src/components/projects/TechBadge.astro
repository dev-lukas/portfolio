---
interface Props {
  name: string;
  color: string;
}

const { name, color } = Astro.props;
---

<span
  class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-full border transition-colors duration-300 hover:bg-white/5"
  style={`border-color: ${color}30; color: ${color}`}
>
  <span class="w-1.5 h-1.5 rounded-full" style={`background: ${color}`} />
  {name}
</span>

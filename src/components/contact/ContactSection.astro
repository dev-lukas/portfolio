---
---

<section id="contact" class="relative py-24">
  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <!-- U-Bahn terminus -->
    <div class="flex items-center gap-4 mb-16 reveal-up">
      <div class="flex items-center gap-2">
        <div class="flex items-center justify-center w-7 h-7 rounded-full bg-accent-yellow text-bg-primary text-xs font-bold">U</div>
        <div class="h-[3px] w-12 bg-accent-yellow/40 rounded-full" />
      </div>
      <div class="relative">
        <!-- Terminal station dot with pulse -->
        <div class="w-4 h-4 rounded-full bg-accent-yellow" />
        <div class="absolute inset-0 w-4 h-4 rounded-full bg-accent-yellow animate-ping opacity-30" />
      </div>
      <span class="text-xs font-mono text-accent-yellow/60 uppercase tracking-widest">End Station</span>
    </div>

    <div class="max-w-2xl">
      <h2 class="reveal-up text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-text-accent mb-6">
        Let's Connect<span class="text-accent-blue">.</span>
      </h2>

      <p class="reveal-up text-lg text-text-secondary leading-relaxed mb-10">
        Interested in working together, have a question about one of my projects, or looking for a DevOps / infrastructure engineer? I'd love to hear from you.
      </p>

      <div class="reveal-up flex flex-wrap gap-4">
        <!-- GitHub -->
        <a
          href="https://github.com/dev-lukas"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-6 py-3 text-sm font-medium text-text-accent bg-bg-secondary border border-white/10 rounded-xl hover:border-accent-blue/30 hover:bg-bg-tertiary transition-all duration-300"
        >
          <svg class="w-5 h-5 text-text-secondary group-hover:text-text-accent transition-colors" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/>
          </svg>
          <span>GitHub</span>
          <span class="text-text-secondary/40 text-xs">@dev-lukas</span>
        </a>

        <!-- Email -->
        <a
          href="mailto:mail@lukas-roth.dev"
          class="group inline-flex items-center gap-3 px-6 py-3 text-sm font-medium text-text-accent bg-accent-blue/10 border border-accent-blue/20 rounded-xl hover:bg-accent-blue/20 hover:border-accent-blue/40 transition-all duration-300"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <span>Email Me</span>
        </a>
      </div>
    </div>
  </div>
</section>

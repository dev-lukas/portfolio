---
---

<!-- Fernsehturm scroll progress indicator - desktop only -->
<div id="scroll-progress" class="fixed right-6 top-1/2 -translate-y-1/2 z-40 hidden lg:block opacity-0 transition-opacity duration-500">
  <div class="relative w-5 h-48">
    <!-- Gray tower (full, always visible) -->
    <svg class="absolute inset-0 w-full h-full text-text-secondary/15" viewBox="0 0 20 200" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="10" y1="5" x2="10" y2="45"/>
      <ellipse cx="10" cy="55" rx="7" ry="10"/>
      <line x1="10" y1="65" x2="10" y2="185"/>
      <path d="M6 185 L10 178 L14 185"/>
      <line x1="5" y1="190" x2="15" y2="190"/>
    </svg>

    <!-- Blue tower (clipped from top, revealed on scroll) -->
    <svg class="absolute inset-0 w-full h-full text-accent-blue" viewBox="0 0 20 200" fill="none" stroke="currentColor" stroke-width="1.5">
      <defs>
        <clipPath id="tower-clip">
          <rect id="tower-clip-rect" x="0" y="0" width="20" height="0"/>
        </clipPath>
      </defs>
      <g clip-path="url(#tower-clip)">
        <line x1="10" y1="5" x2="10" y2="45"/>
        <ellipse cx="10" cy="55" rx="7" ry="10"/>
        <line x1="10" y1="65" x2="10" y2="185"/>
        <path d="M6 185 L10 178 L14 185"/>
        <line x1="5" y1="190" x2="15" y2="190"/>
      </g>
    </svg>
  </div>
</div>

<script>
  const progressEl = document.getElementById('scroll-progress')!;
  const clipRect = document.getElementById('tower-clip-rect')!;

  function updateProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = Math.min(scrollTop / docHeight, 1);

    // Show after scrolling past hero
    progressEl.style.opacity = scrollTop > window.innerHeight * 0.5 ? '1' : '0';

    // Reveal blue tower from top to bottom (viewBox height is 200)
    clipRect.setAttribute('height', String(progress * 200));
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>
